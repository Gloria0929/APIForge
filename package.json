{
  "name": "apiforge",
  "version": "1.0.2",
  "description": "AI 自动化 API 测试平台",
  "main": "dist/main.js",
  "scripts": {
    "sync:env": "node scripts/sync-env-version.js",
    "build": "tsc",
    "start": "node dist/main.js",
    "dev": "ts-node-dev src/main.ts",
    "test": "jest",
    "predocker:build": "npm run sync:env",
    "docker:build": "docker build -t apiforge:latest .",
    "docker:run": "docker run -p 3000:3000 -v apiforge-data:/app/data apiforge:latest",
    "docker:run:update": "docker run -p 3000:3000 -v apiforge-data:/app/data -v /var/run/docker.sock:/var/run/docker.sock apiforge:latest",
    "docker:push": "bash scripts/docker-push.sh"
  },
  "keywords": [
    "api",
    "test",
    "ai",
    "nestjs"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@nestjs/bull": "^11.0.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/typeorm": "^11.0.0",
    "axios": "^1.4.0",
    "bull": "^4.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "dockerode": "^4.0.9",
    "jsonrepair": "^3.13.3",
    "pg": "^8.20.0",
    "redis": "^4.0.0",
    "sqlite3": "^5.1.7",
    "typeorm": "^0.3.17",
    "winston": "^3.9.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "playwright": "^1.58.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
