# 服务
PORT=3000
NODE_ENV=development

# 数据库（默认 SQLite）
DB_TYPE=sqlite
DB_SQLITE_PATH=apiforge.db
DB_SYNC=true

# PostgreSQL（可选，DB_TYPE=postgres 时使用）
# DATABASE_URL=
# DB_HOST=localhost
# DB_PORT=5432
# DB_USERNAME=postgres
# DB_PASSWORD=
# DB_NAME=apiforge
# DB_SSL=false

# 版本检查：优先从 Docker Hub API 自动检测（需 DOCKER_IMAGE 含仓库路径如 foehao09/apiforge）
# 若检测失败或未配置 DOCKER_IMAGE，则回退到 VERSION_LATEST
# VERSION_LATEST=1.0.5
# 可选：更新说明链接
# VERSION_RELEASE_URL=https://github.com/Gloria0929/APIForge/releases

# Docker 更新（需挂载 -v /var/run/docker.sock:/var/run/docker.sock）
# 更新时执行：docker stop apiforge && docker rm -f apiforge && docker run ...
# DOCKER_IMAGE=foehao09/apiforge:latest
# DOCKER_DATA_VOLUME=apiforge_apiforge-data
